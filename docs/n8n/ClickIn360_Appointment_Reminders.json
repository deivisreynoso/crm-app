      "id": "eea3bfc3-8e04-407f-ab00-16b003bc42d6",
      "name": "Wait Until 24h Before",
      "webhookId": "4c503ae6-0adc-4a3f-9415-46f326aa41e7"
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst isEn = d.locale === 'en';\nconst subject = isEn ? 'Your appointment tomorrow with ClickIn360' : 'Tu cita de ma\u00f1ana con ClickIn360';\nlet text = isEn ? `Hi ${d.contact_name}, reminder: appointment tomorrow with ClickIn360.` : `Hola ${d.contact_name}, recordatorio: cita ma\u00f1ana con ClickIn360.`;\nif (d.location_type === 'google_meet' && d.meet_link) text += `\\n\\nJoin: ${d.meet_link}`;\nelse if (d.location_details) text += `\\n\\nLocation: ${d.location_details}`;\nreturn [{ json: { toEmail: d.contact_email, subject, text } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        -120
      ],
      "id": "e293d296-a060-44a2-84f1-ff92f07b6945",
