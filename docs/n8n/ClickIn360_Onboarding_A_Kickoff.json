      "id": "49f205e3-f59f-4149-9187-59955231e745",
      "name": "Config: Edit These Values"
    },
    {
      "parameters": {
        "jsCode": "const root = $input.first().json;\nconst cfg = { \n  crm_base_url: root.crm_base_url \n};\n\n// Payload is nested under root.body when coming from webhook\nconst body = root.body || root;\nconst event = body.event;\nconst workspaceOwnerId = body.workspace_owner_id;\nconst emittedAt = body.emitted_at;\nconst payload = body.payload || {};\nconst document = payload.document || {};\nconst invoice = payload.invoice || {};\nconst contact = payload.contact || document.contact || invoice.contact || {};\n\nconst contactId = \n  payload.contact_id || \n  contact.id || \n  document.contact_id || \n  invoice.contact_id || \n  null;\n\nconst documentId = \n  payload.document_id || \n  document.id || \n  invoice.quote_id || \n  payload.invoice_id || \n  payload.quote_id || \n  null;\n\nconst idempotencyKey = documentId \n  ? `${contactId}:${documentId}` \n  : `${contactId}:no-quote`;\n\nconst crmBase = (cfg.crm_base_url || 'https://www.clickin360.com').replace(/\\/$/, '');\n\nconst onboardingToken = payload.onboarding_token || contact.onboarding_token || null;\nconst onboardingUrl = onboardingToken \n  ? `${crmBase}/onboarding/${onboardingToken}` \n  : null;\n\nconst locale = contact.preferred_language === 'en' ? 'en' : 'es';\nconst firstName = contact.first_name || 'there';\nconst contactEmail = contact.email || null;\n\nlet action = 'stop';\nlet reason = '';\n\nif (event === 'onboarding.manual_start') {\n  action = 'start';\n\n} else if (event === 'invoice.paid') {\n  if (invoice.invoice_type === 'quote' || invoice.quote_id) {\n    action = 'start';\n  } else {\n    reason = 'invoice is not quote-type';\n  }\n\n} else if (event === 'quote.accepted') {\n  action = 'record_quote';\n\n} else {\n  reason = `unhandled event: ${event}`;\n}\n\nreturn [{ \n  json: { \n    event, \n    action,\n    reason,\n    payload, \n    document, \n    invoice, \n    contact, \n    contactId, \n    documentId, \n    workspaceOwnerId, \n    idempotencyKey, \n    onboardingUrl, \n    locale, \n    contactEmail,\n    firstName,\n    emitted_at: emittedAt,\n    ...cfg \n  } \n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1152,
        80
      ],
      "id": "5e7cd4ce-4fed-4988-9f94-8817a124f8d6",
      "name": "Parse CRM Payload"
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nlet action = 'stop';\nlet reason = '';\nif (d.event === 'onboarding.manual_start') { action = 'start'; reason = 'manual_override'; }\nelse if (d.event === 'quote.accepted') { action = 'record_quote'; reason = 'quote_accepted_pending_invoice'; }\nelse if (d.event === 'invoice.paid') {\n  const quoteId = d.invoice?.quote_id || d.documentId;\n  action = 'start';\n  reason = quoteId ? 'invoice_paid_with_quote' : 'invoice_paid_no_quote';\n}\nreturn [{ json: { ...d, action, reason } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1408,
        80
      ],
      "id": "b9b6a3f6-9128-478a-bc2b-0f5d8794a916",
