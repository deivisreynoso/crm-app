        "jsCode": "const d = $('Gate: Should Start Onboarding?').first().json;\nreturn [{ json: { idempotency_key: d.idempotencyKey, contact_id: String(d.contactId), document_id: d.documentId ? String(d.documentId) : null, workspace_owner_id: String(d.workspaceOwnerId), status: 'quote_accepted', quote_accepted_at: new Date().toISOString() } }];"
