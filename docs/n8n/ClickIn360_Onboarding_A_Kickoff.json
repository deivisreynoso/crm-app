      "id": "415e7478-bde9-4bbe-95f6-5bb690fcd03b",
      "name": "IF New Run?"
    },
    {
      "parameters": {
        "jsCode": "const d = $('Gate: Should Start Onboarding?').first().json;\nconst booking = ($env.BOOKING_OFFERS_URL || ($env.CRM_BASE_URL + '/api/leads/booking-offers?lang=es'));\nconst isEn = d.locale === 'en';\nconst subject = isEn ? 'Welcome to ClickIn 360 \u2014 next steps' : 'Bienvenido a ClickIn 360 \u2014 siguientes pasos';\nconst text = isEn\n  ? `Hi ${d.firstName},\\n\\nWelcome to ClickIn 360! Your onboarding has started.\\n\\n1) Complete the questionnaire: ${d.onboardingUrl || '(link will be sent separately)'}\\n2) Book your kickoff call: ${booking}\\n\\nThank you!`\n  : `Hola ${d.firstName},\\n\\n\u00a1Bienvenido a ClickIn 360! Tu incorporaci\u00f3n ha comenzado.\\n\\n1) Completa el cuestionario: ${d.onboardingUrl || '(enlace por separado)'}\\n2) Agenda tu llamada de inicio: ${booking}\\n\\n\u00a1Gracias!`;\nreturn [{ json: { ...d, subject, text, toEmail: d.contactEmail } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
