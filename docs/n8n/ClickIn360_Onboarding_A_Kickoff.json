    {
      "parameters": {
        "jsCode": "const d = $('Gate: Should Start Onboarding?').first().json;\nconst contactRow = $input.first().json || {};\nconst crmBase = (d.crm_base_url || 'https://www.clickin360.com').replace(/\\/$/, '');\n\nlet existingToken = null;\nif (d.onboardingUrl) {\n  const parts = d.onboardingUrl.split('/onboarding/');\n  existingToken = parts[1] || null;\n}\nif (!existingToken) existingToken = contactRow.onboarding_token || null;\n\nlet token = existingToken;\nlet needTokenSave = false;\nif (!token) {\n  const { randomUUID } = require('crypto');\n  token = randomUUID().replace(/-/g, '');\n  needTokenSave = true;\n}\n\nconst locale = contactRow.preferred_language === 'en' || d.locale === 'en' ? 'en' : 'es';\nconst onboardingUrl = `${crmBase}/onboarding/${token}`;\nconst bookingUrl = locale === 'en'\n  ? `${crmBase}/en/book-call`\n  : `${crmBase}/es/book-call`;\n\nconst isEn = locale === 'en';\nconst subject = isEn ? 'Welcome to ClickIn 360 — next steps' : 'Bienvenido a ClickIn 360 — siguientes pasos';\nconst text = isEn\n  ? `Hi ${d.firstName},\\n\\nWelcome to ClickIn 360! Your onboarding has started.\\n\\n1) Complete the questionnaire: ${onboardingUrl}\\n2) Book your kickoff call: ${bookingUrl}\\n\\nThank you!`\n  : `Hola ${d.firstName},\\n\\n¡Bienvenido a ClickIn 360! Tu incorporación ha comenzado.\\n\\n1) Completa el cuestionario: ${onboardingUrl}\\n2) Agenda tu llamada de inicio: ${bookingUrl}\\n\\n¡Gracias!`;\n\nreturn [{ json: { ...d, locale, subject, text, toEmail: d.contactEmail, onboardingUrl, bookingUrl, needTokenSave, onboarding_token: token } }];"
      },
