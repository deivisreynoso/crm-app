      "name": "Config: Edit These Values1"
    },
    {
      "parameters": {
        "jsCode": "const config = $input.first().json;\nconst webhook = $('CRM Router Webhook1').first().json;\n\nconst expected = (config.crm_outbound_webhook_secret || '').trim();\nif (!expected || expected === 'PASTE_SAME_SECRET_AS_CRM_HERE') {\n  throw new Error('Edit the Config node: replace PASTE_SAME_SECRET_AS_CRM_HERE with your real secret.');\n}\n\nconst rawHeaders = webhook.headers || {};\nconst headerSecret = Object.entries(rawHeaders)\n  .find(([k]) => k.toLowerCase() === 'x-crm-webhook-secret')?.[1];\nconst secret = String(headerSecret || '').trim();\n\nif (!secret) {\n  throw new Error('Missing x-crm-webhook-secret header. CRM must send it, or test with curl -H \"x-crm-webhook-secret: ...\"');\n}\n\nif (secret !== expected) {\n  throw new Error('Secret mismatch: header does not match Config node. Use the exact same value in CRM and n8n.');\n}\n\nfunction extractPayload(src) {\n  if (src.body && typeof src.body === 'object' && src.body.event) return src.body;\n  if (src.event) {\n    const { headers, params, query, body, crm_outbound_webhook_secret, n8n_webhook_base, ...rest } = src;\n    if (rest.event) return rest;\n  }\n  return src;\n}\n\nconst crm = extractPayload(webhook);\nconst event = crm.event || config.event;\nif (!event) {\n  throw new Error('No event in webhook body.');\n}\n\nreturn [{\n  json: {\n    event,\n    workspace_owner_id: crm.workspace_owner_id || config.workspace_owner_id,\n    emitted_at: crm.emitted_at || config.emitted_at,\n    payload: crm.payload || config.payload || {},\n    n8n_webhook_base: (config.n8n_webhook_base || '').replace(/\\/$/, ''),\n  },\n}];"
      },
