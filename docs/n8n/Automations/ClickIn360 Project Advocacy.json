    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst isEn = d.locale === 'en';\nconst subject = isEn ? `Would you leave us a Google review, ${d.firstName}?` : `¿Nos dejas una reseña en Google, ${d.firstName}?`;\nconst text = isEn\n  ? `Hi ${d.firstName},\\n\\nThank you for the positive feedback on your project. If you have a moment, a Google review would mean a lot:\\n\\n${d.reviewUrl}\\n\\nIt only takes a minute. Thank you!`\n  : `Hola ${d.firstName},\\n\\nGracias por el feedback positivo sobre tu proyecto. Si tienes un momento, una reseña en Google nos ayudaría mucho:\\n\\n${d.reviewUrl}\\n\\nSolo toma un minuto. ¡Gracias!`;\nreturn [{ json: { ...d, subject, text, toEmail: d.contactEmail } }];"
      },
      "type": "n8n-nodes-base.code",
