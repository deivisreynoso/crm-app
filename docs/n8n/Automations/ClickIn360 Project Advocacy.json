      "webhookId": "f3a8c2d1-4e5b-6a7f-8c9d-0e1f2a3b4c5d"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "cfg-crm-base",
              "name": "crm_base_url",
              "value": "https://www.clickin360.com",
              "type": "string"
            },
            {
              "id": "cfg-google-reviews",
              "name": "google_reviews_url",
              "value": "https://g.page/r/CeVI5TJuGN_GEAI/review",
              "type": "string"
            },
            {
              "id": "cfg-threshold",
              "name": "review_score_threshold",
              "value": "4",
              "type": "string"
            },
            {
              "id": "cfg-delay",
              "name": "google_review_delay_hours",
              "value": "24",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -848,
        128
      ],
      "id": "2c421cbe-8c26-42da-af09-30204a8d723d",
      "name": "Config: Edit These Values"
    },
    {
      "parameters": {
        "jsCode": "const root = $input.first().json;\nconst event = root.event || root.body?.event;\nconst payload = root.payload || root.body?.payload || {};\nconst contact = payload.contact || {};\nconst settings = payload.project_stages_settings || {};\nconst locale = contact.preferred_language === 'en' ? 'en' : 'es';\nconst threshold = Number(root.review_score_threshold || settings.review_score_threshold || 4);\nconst delayHours = Number(root.google_review_delay_hours || settings.google_review_delay_hours || 24);\nconst autoReview = settings.automatic_google_review_enabled !== false;\nconst reviewUrl = root.google_reviews_url || 'https://share.google/CZL2ZHAKEqVgdIEuJ';\nconst feedbackUrl = contact.project_feedback_url || (contact.project_feedback_token ? `${(root.crm_base_url || '').replace(/\\/$/, '')}/project-feedback/${contact.project_feedback_token}` : null);\nconst score = Number(payload.feedback_score ?? payload.opportunity?.feedback_score ?? 0);\nconst guardrailPass = autoReview && contact.review_request_opt_out !== true && score >= threshold;\nreturn [{ json: { event, payload, contact, locale, threshold, delayHours, autoReview, guardrailPass: guardrailPass ? 'yes' : 'no', reviewUrl, feedbackUrl, score, contactEmail: contact.email, firstName: contact.first_name || 'there', contactId: contact.id, optOut: contact.review_request_opt_out === true, opportunityId: payload.opportunity_id, skip: feedbackUrl ? 'no' : 'yes' } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -560,
        128
      ],
      "id": "e637b682-5051-4c7a-bdf0-eb421bad3de1",
      "name": "Parse Project Payload"
    },
    {
      "parameters": {
        "rules": {
          "values": [
