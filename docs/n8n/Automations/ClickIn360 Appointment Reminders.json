      "id": "35b7e9da-8196-43e5-8897-bf7072e35715",
      "name": "Config: Edit These Values"
    },
    {
      "parameters": {
        "jsCode": "const root = $input.first().json;\nconst body = root.body || root;\nconst event = body.event || root.event;\nconst payload = body.payload || root.payload || {};\nconst ev = payload.calendar_event || {};\nconst contact = payload.contact || ev.contact || {};\nconst start = ev.start_time || ev.start_at;\nconst locale = contact.preferred_language === 'en' ? 'en' : 'es';\nconst additional_contacts = Array.isArray(payload.additional_contacts) ? payload.additional_contacts : [];\nconst meet_link = ev.meet_link || ev.google_meet_link || (ev.location_type === 'google_meet' ? ev.location : null) || null;\nreturn [{ json: {\n  event,\n  workspace_owner_id: body.workspace_owner_id || root.workspace_owner_id,\n  event_id: String(ev.id || payload.calendar_event_id || ''),\n  contact_id: String(ev.contact_id || contact.id || ''),\n  start_time: start,\n  meet_link,\n  location_type: ev.location_type || 'other',\n  location_details: (ev.location_type === 'google_meet' ? null : ev.location) || ev.location_details || null,\n  contact_email: contact.email || ev.contact_email || null,\n  contact_phone: contact.phone || ev.contact_phone || null,\n  contact_name: [contact.first_name, contact.last_name].filter(Boolean).join(' ') || ev.contact_name || 'there',\n  locale,\n  additional_contacts,\n  title: ev.title || 'Appointment',\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        160
      ],
      "id": "0de923af-9ab5-455f-a1aa-b763a3c3622a",
      "name": "Parse Appointment Event"
