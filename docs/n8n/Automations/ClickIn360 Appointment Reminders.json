    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nif (d.event !== 'appointment.created' || !d.contact_email) {\n  return [{ json: { ...d, skip_confirmation: true } }];\n}\nconst isEn = d.locale === 'en';\nconst when = d.start_time ? new Date(d.start_time).toLocaleString(isEn ? 'en-US' : 'es-MX', { dateStyle: 'full', timeStyle: 'short' }) : '';\nlet text = isEn\n  ? 'Hi ' + d.contact_name + ',\\n\\nYour appointment \"' + (d.title || 'appointment') + '\" is confirmed.\\n\\n' + when\n  : 'Hola ' + d.contact_name + ',\\n\\nTu cita \"' + (d.title || 'cita') + '\" está confirmada.\\n\\n' + when;\nif (d.location_type === 'google_meet' && d.meet_link) {\n  text += '\\n\\n' + (isEn ? 'Join with Google Meet:' : 'Únete con Google Meet:') + '\\n' + d.meet_link;\n} else if (d.location_details) {\n  text += '\\n\\n' + d.location_details;\n}\nreturn [{ json: { ...d, toEmail: d.contact_email, subject: isEn ? 'Appointment confirmed — ClickIn 360' : 'Cita confirmada — ClickIn 360', text } }];"
      },
