    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nif (!d.start_time) throw new Error('Missing start_time — check Parse Appointment Event output');\nconst start = new Date(d.start_time);\nif (Number.isNaN(start.getTime())) throw new Error('Invalid start_time: ' + d.start_time);\nconst now = new Date();\nconst h24 = new Date(start.getTime() - 24*60*60*1000);\nconst h1 = new Date(start.getTime() - 60*60*1000);\nreturn [{ json: { ...d, reminder_24h_at: h24.toISOString(), reminder_1h_at: h1.toISOString(), skip24: h24 <= now, skip1: h1 <= now, status: (h24 <= now && h1 <= now) ? 'skipped' : 'scheduled' } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
