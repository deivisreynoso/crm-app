# Copy to .env.local on the VPS:  cp .env.local.example .env.local
# Legacy short template: see env.local.example (deprecated — use this file).

# ── Organization (single ClickIn 360 deployment) ─────────────────────────────
# Supabase Auth → Users → organization owner UID. All CRM rows use this as user_id.
CLICKIN360_ORG_USER_ID=
# Legacy alias (supported during migration):
# WEBSITE_LEADS_USER_ID=
# DEFAULT_WEB_LEADS_ASSIGNEE_EMAIL=elizabeth@clickin360.com
# OWNER_LOGIN_ALIASES=deivis@clickin360.com,deivis.reynoso@gmail.com

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.clickin360.com
NEXTAUTH_URL=https://www.clickin360.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Google OAuth (SSO + Gmail/Calendar/Drive) ────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional per-integration redirect overrides (must match Google Cloud Console)
# GOOGLE_GMAIL_REDIRECT_URI=https://www.clickin360.com/api/auth/google-gmail/callback
# GOOGLE_CALENDAR_REDIRECT_URI=https://www.clickin360.com/api/auth/google-calendar/callback
# GOOGLE_DRIVE_REDIRECT_URI=https://www.clickin360.com/api/auth/google-drive/callback

# ── Public API secrets (timing-safe header validation) ───────────────────────
# Generate with: openssl rand -hex 32
WEBSITE_LEADS_API_SECRET=
WEBCHAT_POLL_SECRET=
N8N_CRM_WEBHOOK_SECRET=
# Legacy alias used by some N8N nodes:
N8N_WEBHOOK_SECRET=

# ── Optional shared rate limiting (multi-instance VPS) ───────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Google Analytics 4 (admin Analytics tab) ─────────────────────────────────
GA4_PROPERTY_ID=
GOOGLE_ANALYTICS_CLIENT_EMAIL=
GOOGLE_ANALYTICS_PRIVATE_KEY=

# ── WhatsApp Business API ────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Outbound automation ──────────────────────────────────────────────────────
CRM_OUTBOUND_WEBHOOK_SECRET=

# ── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (team invites) ─────────────────────────────────────────────────────
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mail.clickin360.com
# MAILGUN_FROM=ClickIn 360 <no-reply@clickin360.com>

# ── Playwright E2E ───────────────────────────────────────────────────────────
# E2E_EMAIL=owner@example.com
# E2E_PASSWORD=your-test-password
# WEBSITE_LEADS_API_SECRET=required for lead API E2E
# PLAYWRIGHT_BASE_URL=http://localhost:3000
