# Copy to .env.local on the VPS:  cp .env.local.example .env.local
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App URL (production)
NEXT_PUBLIC_APP_URL=https://www.clickin360.com
NEXTAUTH_URL=https://www.clickin360.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Workspace owner UUID (Lead API tenant) + optional alias emails for same profile
# WEBSITE_LEADS_USER_ID=
# OWNER_LOGIN_ALIASES=deivis@clickin360.com,deivis.reynoso@gmail.com

# Google OAuth (Gmail + Calendar integrations)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Stripe — quote checkout after customer acceptance (admin configures in server env)
# Secret key from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
# Webhook signing secret from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=

# Google Analytics 4 — website traffic on Analytics → Website tab (admin only)
# GA4 property resource name, e.g. properties/123456789
GA4_PROPERTY_ID=
# Service account with Analytics Data API + Viewer on the GA4 property
GOOGLE_ANALYTICS_CLIENT_EMAIL=
# PEM private key; use \n for line breaks in .env.local
GOOGLE_ANALYTICS_PRIVATE_KEY=

# Transactional email — team invites (optional; copy link in UI if unset)
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mail.clickin360.com
# MAILGUN_FROM=ClickIn 360 <no-reply@mail.clickin360.com>
